        </div>
    </div>

    <!-- 3. 備份與同步 Modal -->
    <div id="backupModal" class="fixed inset-0 bg-milktea-900/40 backdrop-blur-sm z-50 hidden opacity-0 transition-opacity flex items-center justify-center p-4">
        <div class="bg-white w-full max-w-sm rounded-3xl shadow-2xl overflow-hidden">
            <div class="p-5 border-b border-milktea-100 flex justify-between items-center bg-milktea-50">
                <h2 class="text-lg font-bold text-milktea-800"><i class="fa-solid fa-cloud-arrow-down mr-2"></i>備份與同步</h2>
                <button onclick="closeModal('backupModal')" class="text-milktea-400 hover:text-milktea-600">
                    <i class="fa-solid fa-xmark text-xl"></i>
                </button>
            </div>
            <div class="p-6 space-y-6">
                <div>
                    <h3 class="text-sm font-bold text-milktea-800 mb-2 border-b border-milktea-100 pb-1">雲端自動存檔狀態</h3>
                    <p class="text-xs text-milktea-600 mb-2">系統已自動將資料綁定於您當前設備的瀏覽器。若要跨設備同步，請使用下方的匯出/匯入功能。</p>
                    <div class="bg-milktea-50 rounded-lg p-2 text-xs font-mono text-center text-milktea-400 truncate" id="cloudSyncId">
                        UID: 讀取中...
                    </div>
                </div>

                <div>
                    <h3 class="text-sm font-bold text-milktea-800 mb-2 border-b border-milktea-100 pb-1">實體檔案備份 (JSON)</h3>
                    <div class="grid grid-cols-2 gap-3">
                        <button onclick="exportData()" class="py-3 px-4 bg-milktea-100 text-milktea-700 rounded-xl hover:bg-milktea-200 transition text-sm font-medium flex flex-col items-center gap-1">
                            <i class="fa-solid fa-download text-lg"></i>
                            匯出備份
                        </button>
                        <button onclick="document.getElementById('importFile').click()" class="py-3 px-4 bg-milktea-100 text-milktea-700 rounded-xl hover:bg-milktea-200 transition text-sm font-medium flex flex-col items-center gap-1">
                            <i class="fa-solid fa-upload text-lg"></i>
                            匯入資料
                        </button>
                        <input type="file" id="importFile" accept=".json" class="hidden" onchange="importData(event)">
                    </div>
                </div>
            </div>
        </div>
