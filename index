<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>M.Y. 靈感收納箱 🤎</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- FontAwesome for Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <!-- Google Fonts: Noto Sans TC -->
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+TC:wght@400;500;700&display=swap" rel="stylesheet">
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        milktea: {
                            50: '#fdfbf7',  /* 極淺奶茶底色 */
                            100: '#f6f0e6',
                            200: '#eee3cf',
                            300: '#e1cdb0',
                            400: '#d2b48c', /* 經典奶茶 */
                            500: '#c29b68',
                            600: '#b48455',
                            700: '#966a46',
                            800: '#7a573b', /* 深焙文字色 */
                            900: '#644732',
                        }
                    },
                    fontFamily: {
                        sans: ['"Noto Sans TC"', 'sans-serif'],
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-color: #fdfbf7;
            color: #644732;
            -webkit-tap-highlight-color: transparent;
        }
        /* 隱藏滾動條但保持可滾動 */
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: #e1cdb0;
            border-radius: 10px;
        }
        /* 瀑布流排版 (Masonry) */
        .masonry-grid {
            column-count: 2;
            column-gap: 1rem;
        }
        @media (max-width: 640px) {
            .masonry-grid {
                column-count: 2; /* 手機版也是雙欄，像 IG 探索 */
                column-gap: 0.75rem;
            }
        }
        .masonry-item {
            break-inside: avoid;
            margin-bottom: 1rem;
        }
        @media (max-width: 640px) {
            .masonry-item {
                margin-bottom: 0.75rem;
            }
        }
        /* 溫柔的卡片陰影與過渡效果 */
        .card-shadow {
            box-shadow: 0 4px 20px rgba(150, 106, 70, 0.06);
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }
        .card-shadow:active {
            transform: scale(0.98);
        }
        /* 浮動按鈕動畫 */
        .fab-button {
            box-shadow: 0 4px 15px rgba(194, 155, 104, 0.4);
        }
        /* 圖片佔位符 */
        .img-placeholder {
            background: repeating-linear-gradient(
                45deg,
                #f6f0e6,
                #f6f0e6 10px,
                #fdfbf7 10px,
                #fdfbf7 20px
            );
        }
    </style>
</head>
<body class="font-sans antialiased min-h-screen pb-24">

    <!-- 頂部導覽列 -->
    <header class="sticky top-0 z-30 bg-milktea-50/90 backdrop-blur-md border-b border-milktea-200 shadow-sm">
        <div class="max-w-5xl mx-auto px-4 py-3">
            <div class="flex justify-between items-center mb-3">
                <h1 class="text-xl font-bold text-milktea-800 flex items-center gap-2">
                    <i class="fa-solid fa-mug-hot text-milktea-500"></i>
                    靈感收納箱
                </h1>
                <div class="flex gap-3">
                    <button onclick="openModal('backupModal')" class="w-10 h-10 rounded-full bg-milktea-100 text-milktea-700 flex items-center justify-center hover:bg-milktea-200 transition">
                        <i class="fa-solid fa-cloud-arrow-down"></i>
                    </button>
                    <button onclick="openModal('categoryEditModal')" class="w-10 h-10 rounded-full bg-milktea-100 text-milktea-700 flex items-center justify-center hover:bg-milktea-200 transition">
                        <i class="fa-solid fa-folder-tree"></i>
                    </button>
                </div>
            </div>
            
            <!-- 搜尋框 -->
            <div class="relative">
                <i class="fa-solid fa-magnifying-glass absolute left-4 top-1/2 transform -translate-y-1/2 text-milktea-400"></i>
                <input type="text" id="searchInput" placeholder="搜尋標題、標籤或內容..." 
                    class="w-full bg-white border border-milktea-200 rounded-full py-2 pl-11 pr-4 text-sm focus:outline-none focus:ring-2 focus:ring-milktea-300 focus:border-transparent transition shadow-inner text-milktea-800 placeholder-milktea-400">
            </div>
        </div>
    </header>

    <!-- 分類標籤滑動區 -->
    <nav class="max-w-5xl mx-auto px-4 py-4">
        <div class="flex overflow-x-auto gap-2 pb-2 scrollbar-hide" id="categoryNav">
            <!-- 動態生成分類按鈕 -->
        </div>
    </nav>

    <!-- 主要內容區 (瀑布流) -->
    <main class="max-w-5xl mx-auto px-4">
        <!-- 狀態提示區 -->
        <div id="loadingIndicator" class="text-center py-10 text-milktea-500 hidden">
            <i class="fa-solid fa-spinner fa-spin text-2xl mb-2"></i>
            <p class="text-sm">正在讀取靈感中...</p>
        </div>
        <div id="emptyState" class="text-center py-16 hidden">
            <div class="w-24 h-24 bg-milktea-100 rounded-full flex items-center justify-center mx-auto mb-4 text-milktea-400 text-4xl">
                <i class="fa-regular fa-folder-open"></i>
            </div>
            <h3 class="text-lg font-medium text-milktea-700 mb-1">這裡還是空的唷</h3>
            <p class="text-sm text-milktea-500">點擊右下角的按鈕，開始收藏妳的第一個靈感吧！</p>
        </div>

        <!-- 卡片網格 -->
        <div class="masonry-grid" id="bookmarksContainer">
            <!-- 動態生成卡片 -->
        </div>
    </main>

    <!-- 右下角浮動新增按鈕 -->
    <button onclick="openAddModal()" class="fab-button fixed bottom-6 right-6 w-14 h-14 bg-milktea-600 text-white rounded-full flex items-center justify-center text-2xl hover:bg-milktea-700 hover:scale-105 transition-all z-40">
        <i class="fa-solid fa-plus"></i>
    </button>

    <!-- ================= 模態框 (Modals) ================= -->

    <!-- 1. 新增/編輯收藏 Modal -->
    <div id="addModal" class="fixed inset-0 bg-milktea-900/40 backdrop-blur-sm z-50 hidden opacity-0 transition-opacity flex items-end sm:items-center justify-center">
        <div class="bg-white w-full sm:w-full sm:max-w-md rounded-t-3xl sm:rounded-3xl max-h-[90vh] flex flex-col shadow-2xl transform translate-y-full sm:translate-y-0 transition-transform duration-300" id="addModalContent">
            
            <div class="flex justify-between items-center p-5 border-b border-milktea-100">
                <h2 class="text-lg font-bold text-milktea-800" id="addModalTitle">✨ 新增靈感</h2>
                <button onclick="closeModal('addModal')" class="text-milktea-400 hover:text-milktea-600 w-8 h-8 flex items-center justify-center rounded-full bg-milktea-50">
                    <i class="fa-solid fa-xmark"></i>
                </button>
            </div>
            
            <div class="p-5 overflow-y-auto custom-scrollbar flex-1">
                <!-- 圖片上傳/貼上區 -->
                <div class="mb-5">
                    <label class="block text-sm font-medium text-milktea-700 mb-2">截圖或圖片 (可直接貼上 📋)</label>
                    <div id="imageDropZone" class="border-2 border-dashed border-milktea-300 rounded-xl p-4 text-center cursor-pointer hover:bg-milktea-50 transition relative overflow-hidden bg-milktea-50/50">
                        <input type="file" id="imageInput" accept="image/*" class="hidden">
                        <div id="imagePreviewContainer" class="hidden">
                            <img id="imagePreview" src="" alt="預覽" class="w-full h-auto rounded-lg object-cover max-h-48">
                            <button type="button" onclick="clearImage(event)" class="absolute top-2 right-2 bg-black/50 text-white rounded-full w-8 h-8 flex items-center justify-center backdrop-blur-sm">
