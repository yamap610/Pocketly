                        <input type="text" id="itemTitle" placeholder="這篇文章的重點是什麼？" class="w-full border border-milktea-200 rounded-lg px-3 py-2 focus:ring-2 focus:ring-milktea-300 focus:outline-none bg-white">
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-milktea-700 mb-1">原始連結 (選填)</label>
                        <input type="url" id="itemUrl" placeholder="https://instagram.com/..." class="w-full border border-milktea-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-milktea-300 focus:outline-none bg-white">
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-milktea-700 mb-1">分類 <span class="text-red-400">*</span></label>
                        <select id="itemCategory" class="w-full border border-milktea-200 rounded-lg px-3 py-2 focus:ring-2 focus:ring-milktea-300 focus:outline-none bg-white appearance-none">
                            <!-- 動態載入分類 -->
                        </select>
                    </div>

                    <div>
                        <div class="flex justify-between items-end mb-1">
                            <label class="block text-sm font-medium text-milktea-700">標籤 (逗號分隔)</label>
                            <button type="button" onclick="generateAITags()" id="aiTagBtn" class="text-xs bg-gradient-to-r from-milktea-400 to-milktea-500 text-white px-2 py-1 rounded-md hover:from-milktea-500 hover:to-milktea-600 shadow-sm flex items-center gap-1">
                                <i class="fa-solid fa-wand-magic-sparkles"></i> AI 幫貼
                            </button>
                        </div>
                        <input type="text" id="itemTags" placeholder="例如：日系, 收納, 靈感" class="w-full border border-milktea-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-milktea-300 focus:outline-none bg-white">
                    </div>
                    
                    <div>
                        <label class="block text-sm font-medium text-milktea-700 mb-1">筆記/心得 (選填)</label>
                        <textarea id="itemNotes" rows="3" placeholder="寫下妳喜歡的原因..." class="w-full border border-milktea-200 rounded-lg px-3 py-2 text-sm focus:ring-2 focus:ring-milktea-300 focus:outline-none bg-white resize-none"></textarea>
                    </div>
                </div>
            </div>
            
            <div class="p-5 border-t border-milktea-100 flex gap-3 bg-white sm:rounded-b-3xl">
                <button onclick="closeModal('addModal')" class="flex-1 py-2.5 rounded-xl border border-milktea-300 text-milktea-700 font-medium hover:bg-milktea-50 transition">取消</button>
                <button onclick="saveBookmark()" id="saveBtn" class="flex-1 py-2.5 rounded-xl bg-milktea-600 text-white font-medium hover:bg-milktea-700 transition shadow-md flex justify-center items-center gap-2">
                    <i class="fa-solid fa-check"></i> 儲存
                </button>
            </div>
        </div>
    </div>

    <!-- 2. 分類編輯 Modal -->
    <div id="categoryEditModal" class="fixed inset-0 bg-milktea-900/40 backdrop-blur-sm z-50 hidden opacity-0 transition-opacity flex items-center justify-center p-4">
        <div class="bg-white w-full max-w-sm rounded-3xl shadow-2xl overflow-hidden flex flex-col max-h-[80vh]">
            <div class="p-5 border-b border-milktea-100 flex justify-between items-center bg-milktea-50">
                <h2 class="text-lg font-bold text-milktea-800"><i class="fa-solid fa-folder-gear mr-2"></i>管理分類</h2>
                <button onclick="closeModal('categoryEditModal')" class="text-milktea-400 hover:text-milktea-600">
                    <i class="fa-solid fa-xmark text-xl"></i>
                </button>
            </div>
            <div class="p-5 overflow-y-auto flex-1 bg-white">
                <div class="flex gap-2 mb-4">
                    <input type="text" id="newCategoryIcon" placeholder="🎨" class="w-12 text-center border border-milktea-200 rounded-lg px-2 py-2 focus:ring-2 focus:ring-milktea-300 outline-none text-lg">
                    <input type="text" id="newCategoryName" placeholder="新分類名稱" class="flex-1 border border-milktea-200 rounded-lg px-3 py-2 focus:ring-2 focus:ring-milktea-300 outline-none text-sm">
                    <button onclick="addCategory()" class="bg-milktea-500 text-white px-3 py-2 rounded-lg hover:bg-milktea-600 transition"><i class="fa-solid fa-plus"></i></button>
                </div>
                <ul id="categoryEditList" class="space-y-2">
